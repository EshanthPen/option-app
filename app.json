{
  "expo": {
    "name": "option-app",
    "slug": "option-app",
    "scheme": "optionapp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F5F3E9"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.eshanthpen.optionapp",
      "buildNumber": "1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSUserNotificationsUsageDescription": "Option sends reminders for upcoming deadlines, grade changes, and focus streaks."
      }
    },
    "android": {
      "package": "com.eshanthpen.optionapp",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-web-browser",
      "expo-font",
      "expo-updates",
      [
        "expo-notifications",
        {
          "color": "#232E52",
          "sounds": []
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "05ff0e9e-d3e9-4879-989d-c01c8344bf2e"
      }
    },
    "owner": "eshanthp",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/05ff0e9e-d3e9-4879-989d-c01c8344bf2e"
    }
  }
}
